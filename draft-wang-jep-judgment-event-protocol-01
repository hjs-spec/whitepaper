   ```json
   {
     "primitive": {
       "type": "BATCH",
       "payload": {
         "operations": [
           {"type": "J", "actor": "did:example:agent1",
            "decision_hash": "..."},
           {"type": "D", "parent": "receipt-1",
            "delegatee": "did:example:agent2"},
           {"type": "T", "target": "receipt-2", "mode": "ARCHIVED"}
